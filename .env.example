# ─────────────────────────────────────────
#  KOB WMS Pro — Environment Configuration
#  Copy to .env and fill in your credentials
# ─────────────────────────────────────────

# Application
VITE_APP_ENV=production

# ── Odoo ERP Connection ──────────────────
VITE_ODOO_URL=https://odoo.yourdomain.com
VITE_ODOO_DB=kob_production
VITE_ODOO_USER=wms_api_user
VITE_ODOO_PASS=your_secure_password_here

# ── Firebase (Realtime Sync) ─────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000:web:abcdef123456

# ── Platform APIs (Marketplaces) ─────────
# Shopee Open Platform
VITE_SHOPEE_PARTNER_ID=
VITE_SHOPEE_PARTNER_KEY=
VITE_SHOPEE_SHOP_ID=
VITE_SHOPEE_ENV=live

# Lazada Open Platform (LazOP)
VITE_LAZADA_APP_KEY=
VITE_LAZADA_APP_SECRET=
VITE_LAZADA_REGION=TH

# TikTok Shop
VITE_TIKTOK_APP_KEY=
VITE_TIKTOK_APP_SECRET=

# ── Platform APIs (Couriers) ─────────────
# Flash Express
VITE_FLASH_MCH_ID=
VITE_FLASH_SECRET_KEY=
VITE_FLASH_ENV=live

# Kerry Express (Smart-Edi)
VITE_KERRY_CUSTOMER_ID=
VITE_KERRY_USERNAME=
VITE_KERRY_PASSWORD=

# J&T Express
VITE_JT_COMPANY_ID=
VITE_JT_API_ACCOUNT=
VITE_JT_API_KEY=
VITE_JT_ENV=live

# Thai Post
VITE_THAIPOST_API_TOKEN=

# ── AfterShip (Unified tracking fallback) ─
VITE_AFTERSHIP_API_KEY=

# ── Docker / Deployment ──────────────────
NODE_ENV=production

# Docker Compose service ports
WMS_PORT=3000
ODOO_PORT=8069
ODOO_LONGPOLL_PORT=8072
POSTGRES_PORT=5432

# PostgreSQL credentials (REQUIRED — used by Odoo + Postgres containers)
POSTGRES_DB=odoo18
POSTGRES_USER=odoo
POSTGRES_PASSWORD=change_me_to_a_strong_password
